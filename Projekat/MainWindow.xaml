<Window x:Class="Projekat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Projekat.ViewModels"
        xmlns:views="clr-namespace:Projekat.Views"
        Title="Student Performance Analytics" Height="600" Width="900"
        Background="#D6EAF8">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:StudentViewModel}">
            <views:StudentView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PredmetViewModel}">
            <views:PredmetView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:IspitViewModel}">
            <views:IspitView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:StatistikaViewModel}">
            <views:StatistikaView/>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#5DADE2" Height="60" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">

                <Button Content="Studenti" Margin="0,0,10,0"
                        Command="{Binding ShowStudentsCommand}"
                        Background="#85C1E9" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Predmeti" Margin="0,0,10,0"
                        Command="{Binding ShowPredmetiCommand}"
                        Background="#85C1E9" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Ispiti" Margin="0,0,10,0"
                        Command="{Binding ShowIspitiCommand}"
                        Background="#85C1E9" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Statistika" Margin="0,0,10,0"
                        Command="{Binding ShowStatistikaCommand}"
                        Background="#85C1E9" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <Border Margin="20" Background="White" CornerRadius="15" Padding="10">
            <ContentControl Content="{Binding CurrentViewModel}"/>
        </Border>
    </DockPanel>
</Window>