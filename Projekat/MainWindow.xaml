<Window x:Class="Projekat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Projekat.ViewModels"
        Title="Student Performance Analytics"
        Height="600" Width="900"
        WindowState="Maximized"
        Background="#D6EAF8">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#85C1E9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="MinWidth" Value="120"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5DADE2"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2E86C1"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <DockPanel>

        <Border DockPanel.Dock="Top"
                Background="#5DADE2"
                Height="65"
                Padding="15">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left">

                    <Button Content="Studenti"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowStudentsCommand}"/>

                    <Button Content="Predmeti"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowPredmetiCommand}"/>

                    <Button Content="Ispiti"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowIspitiCommand}"/>

                    <Button Content="Statistika"
                            Style="{StaticResource NavButtonStyle}"
                            Margin="0"
                            Command="{Binding ShowStatistikaCommand}"/>

                </StackPanel>

            </Grid>
        </Border>

        <Border Margin="20"
                Background="White"
                CornerRadius="15"
                Padding="10">

            <ContentControl Content="{Binding CurrentViewModel}"/>

        </Border>

    </DockPanel>
</Window>